<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <div class="product-show-header mb-30">
      <div class="product-show-title">
        <h3><%= t("admin.orders.order") %> #<%= @order.id[0, 8] %></h3>
        <div class="product-show-subtitle">
          <span class="<%= order_status_badge_class(@order.status) %> fw-7"><%= translated_order_status(@order.status) %></span>
          <span><%= l(@order.created_at, format: :long) %></span>
        </div>
      </div>

      <div class="product-show-header-actions">
        <% @order.available_status_transitions.each do |next_status| %>
          <%= button_to order_status_action_label(next_status),
                        update_status_admin_order_path(@order),
                        method: :patch,
                        params: { status: next_status },
                        class: "tf-button #{next_status == 'cancelled' ? 'style-1 product-show-danger' : 'style-1'}",
                        form: { data: (next_status == 'cancelled' ? { turbo_confirm: t("admin.orders.cancel_confirmation") } : {}) } %>
        <% end %>
        <%= link_to admin_orders_path, class: "tf-button style-3" do %>
          <i class="icon-arrow-left"></i><%= t("admin.common.back") %>
        <% end %>
      </div>

      <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
        <li>
          <%= link_to admin_dashboard_path do %>
            <div class="text-tiny"><%= t("admin.navigation.dashboard") %></div>
          <% end %>
        </li>
        <li><i class="icon-chevron-right"></i></li>
        <li>
          <%= link_to admin_orders_path do %>
            <div class="text-tiny"><%= t("admin.navigation.orders") %></div>
          <% end %>
        </li>
        <li><i class="icon-chevron-right"></i></li>
        <li>
          <div class="text-tiny"><%= t("admin.common.details") %></div>
        </li>
      </ul>
    </div>

    <div class="product-show-grid product-show-grid-compact mb-30">
      <div class="wg-box product-show-panel">
        <div>
          <div class="body-title mb-10"><%= t("admin.orders.customer_section") %></div>
          <div class="text-tiny"><%= t("admin.orders.buyer_information") %></div>
        </div>

        <div class="divider"></div>

        <div class="product-show-details-list">
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.name") %></span>
            <strong><%= @order.user&.name || "—" %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.email") %></span>
            <strong><%= @order.user&.email || "—" %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.phone") %></span>
            <strong><%= @order.user&.phone.presence || "—" %></strong>
          </div>
        </div>
      </div>

      <div class="wg-box product-show-panel">
        <div>
          <div class="body-title mb-10"><%= t("admin.orders.summary") %></div>
          <div class="text-tiny"><%= t("admin.orders.payment_details") %></div>
        </div>

        <div class="divider"></div>

        <div class="product-show-details-list">
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.status") %></span>
            <strong><%= translated_order_status(@order.status) %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.items") %></span>
            <strong><%= @order.order_items.sum { |i| i.quantity.to_i } %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.created") %></span>
            <strong><%= l(@order.created_at, format: :short) %></strong>
          </div>
        </div>

        <div class="divider"></div>

        <div class="product-show-price">
          <div class="text-tiny"><%= t("admin.orders.total") %></div>
          <div><%= number_to_currency(@order.total) %></div>
        </div>
      </div>
    </div>

    <div class="wg-box mb-30">
      <div>
        <div class="body-title mb-10"><%= t("admin.orders.shipping_address") %></div>
        <div class="text-tiny"><%= t("admin.orders.delivery_details") %></div>
      </div>

      <div class="divider"></div>

      <% if @order.shipping_address? %>
        <div class="product-show-details-list">
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.recipient") %></span>
            <strong><%= @order.shipping_recipient.presence || @order.user&.name || "—" %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.orders.address") %></span>
            <strong><%= @order.shipping_address_line %></strong>
          </div>
        </div>
      <% else %>
        <div class="body-text text-tiny"><%= t("admin.orders.no_shipping_address") %></div>
      <% end %>
    </div>

    <div class="wg-box">
      <div class="flex items-center justify-between">
        <h5><%= t("admin.orders.order_items") %></h5>
      </div>
      <div class="wg-table table-all-category">
        <ul class="table-title flex gap20 mb-14">
          <li><div class="body-title"><%= t("admin.orders.product") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.unit_price") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.quantity") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.subtotal") %></div></li>
        </ul>
        <ul class="flex flex-column">
          <% @order.order_items.each do |item| %>
          <li class="wg-product item-row gap20">
            <div class="name">
              <div class="image">
                <% if item.product %>
                  <%= product_thumbnail_tag(item.product, alt: item.product.name) %>
                <% else %>
                  <span class="icon-image" style="font-size: 24px;"></span>
                <% end %>
              </div>
              <div class="title line-clamp-2 mb-0">
                <span class="body-text fw-6"><%= item.product&.name || t("admin.orders.removed_product") %></span>
              </div>
            </div>
            <div class="body-text text-main-dark mt-4"><%= number_to_currency(item.price) %></div>
            <div class="body-text text-main-dark mt-4"><%= item.quantity %></div>
            <div class="body-text text-main-dark mt-4"><%= number_to_currency(item.price * item.quantity) %></div>
          </li>
          <% end %>
          <% if @order.order_items.empty? %>
          <li class="wg-product item-row gap20">
            <div class="body-text text-tiny"><%= t("admin.orders.no_items") %></div>
          </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
