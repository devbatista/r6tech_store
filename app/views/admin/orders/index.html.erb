<div class="main-content-inner">
  <%= render 'layouts/flash' %>
  <!-- main-content-wrap -->
  <div class="main-content-wrap">
      <div class="flex items-center flex-wrap justify-between gap20 mb-30">
          <h3><%= t("admin.orders.list") %></h3>
          <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
              <li>
                  <%= link_to admin_root_path do %><div class="text-tiny"><%= t("admin.navigation.dashboard") %></div><% end %>
              </li>
              <li>
                  <i class="icon-chevron-right"></i>
              </li>
              <li>
                  <a href="#"><div class="text-tiny"><%= t("admin.orders.order") %></div></a>
              </li>
              <li>
                  <i class="icon-chevron-right"></i>
              </li>
              <li>
                  <div class="text-tiny"><%= t("admin.orders.list") %></div>
              </li>
          </ul>
      </div>
      <!-- order-list -->
      <div class="wg-box">
          <div class="flex items-center justify-between gap10 flex-wrap">
              <div class="wg-filter flex-grow">
                  <form method="get" class="w-auto">
                      <div class="show">
                          <div class="text-tiny"><%= t("views.pagination.showing") %></div>
                          <div class="select">
                              <select name="per" onchange="this.form.submit()">
                                  <option value="10" <%= 'selected' if params[:per].to_s == '10' %>>10</option>
                                  <option value="20" <%= 'selected' if params[:per].to_s == '20' %>>20</option>
                                  <option value="30" <%= 'selected' if params[:per].to_s == '30' %>>30</option>
                              </select>
                          </div>
                          <div class="text-tiny"><%= t("views.pagination.entries") %></div>
                      </div>
                  </form>
              </div>
          </div>
          <div class="wg-table table-all-category">
              <ul class="table-title flex gap20 mb-14">
                  <li>
                      <div class="body-title"><%= t("admin.orders.order") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.orders.customer") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.orders.items") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.orders.total") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.orders.date") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.orders.status") %></div>
                  </li>
                  <li>
                      <div class="body-title"><%= t("admin.common.action") %></div>
                  </li>
              </ul>
              <ul class="flex flex-column">
                  <% @orders.each do |order| %>
                  <li class="wg-product item-row gap20">
                      <div class="name">
                          <div class="image">
                              <% first_product = order.order_items.first&.product %>
                              <% if first_product %>
                                  <%= product_thumbnail_tag(first_product, alt: first_product.name) %>
                              <% else %>
                                  <span class="icon-shopping-cart" style="font-size: 24px;"></span>
                              <% end %>
                          </div>
                          <div class="title line-clamp-2 mb-0">
                              <%= link_to "##{order.id[0, 8]}", admin_order_path(order), class: "body-text fw-6" %>
                          </div>
                      </div>
                      <div class="body-text text-main-dark mt-4"><%= order.user&.name || order.user&.email %></div>
                      <div class="body-text text-main-dark mt-4"><%= order.order_items.sum { |i| i.quantity.to_i } %></div>
                      <div class="body-text text-main-dark mt-4"><%= number_to_currency(order.total) %></div>
                      <div class="body-text text-main-dark mt-4"><%= l(order.created_at, format: :short) %></div>
                      <div>
                          <div class="<%= order_status_badge_class(order.status) %> bg-1 fw-7"><%= translated_order_status(order.status) %></div>
                      </div>
                      <div class="list-icon-function">
                          <div class="item eye">
                              <%= link_to admin_order_path(order) do %>
                                  <i class="icon-eye"></i>
                              <% end %>
                          </div>
                      </div>
                  </li>
                  <% end %>
                  <% if @orders.empty? %>
                  <li class="wg-product item-row gap20">
                      <div class="body-text text-tiny"><%= t("admin.orders.empty") %></div>
                  </li>
                  <% end %>
              </ul>
          </div>
          <div class="divider"></div>
          <div class="flex items-center justify-between flex-wrap gap10">
              <div class="text-tiny"><%= t("views.pagination.showing_count", current: @orders.size, total: @orders.total_count) %></div>
              <ul class="wg-pagination">
                  <li class="<%= 'disabled' unless @orders.prev_page %>">
                      <% if @orders.prev_page %>
                          <%= link_to url_for(page: @orders.prev_page, per: params[:per]) do %>
                              <i class="icon-chevron-left"></i>
                          <% end %>
                      <% else %>
                          <span><i class="icon-chevron-left"></i></span>
                      <% end %>
                  </li>

                  <% (1..@orders.total_pages).each do |page| %>
                      <li class="<%= 'active' if page == @orders.current_page %>">
                          <% if page == @orders.current_page %>
                              <a class="disabled"><%= page %></a>
                          <% else %>
                              <%= link_to page, url_for(page: page, per: params[:per]) %>
                          <% end %>
                      </li>
                  <% end %>

                  <li class="<%= 'disabled' unless @orders.next_page %>">
                      <% if @orders.next_page %>
                          <%= link_to url_for(page: @orders.next_page, per: params[:per]) do %>
                              <i class="icon-chevron-right"></i>
                          <% end %>
                      <% else %>
                          <span><i class="icon-chevron-right"></i></span>
                      <% end %>
                  </li>
              </ul>
          </div>
      </div>
      <!-- /order-list -->
  </div>
  <!-- /main-content-wrap -->
</div>
