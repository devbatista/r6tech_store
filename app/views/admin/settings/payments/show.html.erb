<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: "Payments" %>

    <%= form_with model: @setting, url: admin_settings_payments_path, method: :patch,
                  html: { class: "product-form" } do |form| %>
      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10">Payment methods</div>
          <div class="text-tiny">Methods offered to customers at checkout.</div>
        </div>

        <div class="divider"></div>

        <label class="flex items-center gap10 mb-14">
          <%= form.check_box :pay_pix %>
          <span class="body-text">Pix</span>
        </label>
        <label class="flex items-center gap10 mb-14">
          <%= form.check_box :pay_credit_card %>
          <span class="body-text">Credit card</span>
        </label>
        <label class="flex items-center gap10">
          <%= form.check_box :pay_boleto %>
          <span class="body-text">Boleto</span>
        </label>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i>Save changes</button>
      </div>
    <% end %>
  </div>
</div>
