<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: "Appearance" %>

    <%= form_with model: @setting, url: admin_settings_appearance_path, method: :patch,
                  html: { class: "product-form" } do |form| %>
      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10">Theme</div>
          <div class="text-tiny">Default appearance for the admin panel.</div>
        </div>

        <div class="divider"></div>

        <label class="flex items-center gap10">
          <%= form.check_box :default_dark_mode %>
          <span class="body-text">Use <strong>dark mode</strong> by default</span>
        </label>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i>Save changes</button>
      </div>
    <% end %>
  </div>
</div>
