<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: t("admin.settings.appearance") %>

    <%= form_with model: @setting, url: admin_settings_appearance_path, method: :patch,
                  html: { class: "product-form" } do |form| %>
      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10"><%= t("admin.settings.theme") %></div>
          <div class="text-tiny"><%= t("admin.settings.theme_hint") %></div>
        </div>

        <div class="divider"></div>

        <label class="flex items-center gap10">
          <%= form.check_box :default_dark_mode %>
          <span class="body-text"><%= t("admin.settings.dark_mode") %></span>
        </label>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i><%= t("admin.common.save_changes") %></button>
      </div>
    <% end %>
  </div>
</div>
