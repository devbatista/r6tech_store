<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: t("admin.settings.account") %>

    <%= form_with model: @account, url: admin_settings_account_path, method: :patch,
                  scope: :user, html: { class: "product-form" } do |form| %>
      <% if @account.errors.any? %>
        <div class="wg-box product-form-errors mb-30">
          <div class="body-title"><%= t("admin.settings.check_account") %></div>
          <ul>
            <% @account.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10"><%= t("admin.settings.profile") %></div>
          <div class="text-tiny"><%= t("admin.settings.profile_hint") %></div>
        </div>

        <fieldset class="name">
          <div class="body-title mb-10"><%= t("admin.settings.name") %> <span class="tf-color-1">*</span></div>
          <%= form.text_field :name, required: true %>
        </fieldset>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.email") %> <span class="tf-color-1">*</span></div>
            <%= form.email_field :email, required: true %>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.phone") %></div>
            <%= form.text_field :phone %>
          </fieldset>
        </div>
      </div>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10"><%= t("admin.settings.change_password") %></div>
          <div class="text-tiny"><%= t("admin.settings.keep_password_hint") %></div>
        </div>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.new_password") %></div>
            <%= form.password_field :password, autocomplete: "new-password" %>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.confirm_new_password") %></div>
            <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
          </fieldset>
        </div>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i><%= t("admin.common.save_changes") %></button>
      </div>
    <% end %>
  </div>
</div>
