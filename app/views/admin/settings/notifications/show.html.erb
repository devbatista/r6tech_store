<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: t("admin.settings.notifications") %>

    <%= form_with model: @setting, url: admin_settings_notifications_path, method: :patch,
                  html: { class: "product-form" } do |form| %>
      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10"><%= t("admin.settings.email_notifications") %></div>
          <div class="text-tiny"><%= t("admin.settings.email_notifications_hint") %></div>
        </div>

        <fieldset>
          <div class="body-title mb-10"><%= t("admin.settings.sender_address") %></div>
          <%= form.email_field :notification_sender, placeholder: "no-reply@store.com" %>
        </fieldset>

        <div class="divider"></div>

        <label class="flex items-center gap10 mb-14">
          <%= form.check_box :notify_on_paid %>
          <span class="body-text"><%= t("admin.settings.notify_paid") %></span>
        </label>
        <label class="flex items-center gap10 mb-14">
          <%= form.check_box :notify_on_shipped %>
          <span class="body-text"><%= t("admin.settings.notify_shipped") %></span>
        </label>
        <label class="flex items-center gap10">
          <%= form.check_box :notify_on_delivered %>
          <span class="body-text"><%= t("admin.settings.notify_delivered") %></span>
        </label>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i><%= t("admin.common.save_changes") %></button>
      </div>
    <% end %>
  </div>
</div>
