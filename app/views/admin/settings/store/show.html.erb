<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: "Store" %>

    <%= form_with model: @setting, url: admin_settings_store_path, method: :patch,
                  html: { multipart: true, class: "product-form" } do |form| %>
      <% if @setting.errors.any? %>
        <div class="wg-box product-form-errors mb-30">
          <div class="body-title">Check the store information</div>
          <ul>
            <% @setting.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10">Store profile</div>
          <div class="text-tiny">Basic information shown across the storefront.</div>
        </div>

        <fieldset class="name">
          <div class="body-title mb-10">Store name</div>
          <%= form.text_field :store_name, placeholder: "Enter store name" %>
        </fieldset>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10">Contact email</div>
            <%= form.email_field :contact_email, placeholder: "contact@store.com" %>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10">Contact phone</div>
            <%= form.text_field :contact_phone, placeholder: "+55 11 90000-0000" %>
          </fieldset>
        </div>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10">Currency</div>
            <input type="text" value="Brazilian Real (BRL)" readonly>
            <div class="text-tiny mt-4">The store currency is fixed.</div>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10">Timezone</div>
            <div class="select">
              <%= form.select :timezone, Setting::TIMEZONES %>
            </div>
          </fieldset>
        </div>
      </div>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10">Social links</div>
          <div class="text-tiny">Optional links displayed in the storefront footer.</div>
        </div>

        <fieldset>
          <div class="body-title mb-10">Instagram</div>
          <%= form.url_field :instagram_url, placeholder: "https://instagram.com/yourstore" %>
        </fieldset>

        <fieldset>
          <div class="body-title mb-10">Facebook</div>
          <%= form.url_field :facebook_url, placeholder: "https://facebook.com/yourstore" %>
        </fieldset>

        <fieldset>
          <div class="body-title mb-10">WhatsApp</div>
          <%= form.text_field :whatsapp, placeholder: "+55 11 90000-0000" %>
        </fieldset>
      </div>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10">Logo</div>
          <div class="text-tiny">Recommended a square image (PNG/SVG).</div>
        </div>

        <% if @setting.logo.attached? %>
          <div class="product-form-current-images mb-16">
            <div class="product-form-current-image">
              <%= image_tag @setting.logo.variant(resize_to_limit: [220, 220]), alt: "Store logo" %>
            </div>
          </div>
        <% end %>

        <div class="upload-image mb-16">
          <div class="up-load">
            <label class="uploadfile product-form-upload" for="setting_logo">
              <span class="icon"><i class="icon-upload-cloud"></i></span>
              <div class="text-tiny">Drop a logo here or <span class="text-secondary">browse files</span></div>
              <%= form.file_field :logo, id: "setting_logo", accept: "image/*" %>
            </label>
          </div>
        </div>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit">
          <i class="icon-save"></i>Save changes
        </button>
      </div>
    <% end %>
  </div>
</div>
