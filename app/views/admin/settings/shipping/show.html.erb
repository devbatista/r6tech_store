<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <%= render "admin/settings/header", title: t("admin.settings.shipping_orders") %>

    <%= form_with model: @setting, url: admin_settings_shipping_path, method: :patch,
                  html: { class: "product-form" } do |form| %>
      <% if @setting.errors.any? %>
        <div class="wg-box product-form-errors mb-30">
          <div class="body-title"><%= t("admin.settings.check_values") %></div>
          <ul>
            <% @setting.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="wg-box mb-20">
        <div>
          <div class="body-title mb-10"><%= t("admin.settings.shipping_rules") %></div>
          <div class="text-tiny"><%= t("admin.settings.shipping_rules_hint") %></div>
        </div>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.shipping_fee") %></div>
            <%= form.number_field :shipping_fee, step: 0.01, min: 0, placeholder: "0.00" %>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.free_shipping_threshold") %></div>
            <%= form.number_field :free_shipping_threshold, step: 0.01, min: 0, placeholder: t("admin.settings.free_shipping_threshold_placeholder") %>
          </fieldset>
        </div>

        <div class="product-form-two-columns">
          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.tax_rate") %></div>
            <%= form.number_field :tax_rate, step: 0.01, min: 0, placeholder: "0.00" %>
          </fieldset>

          <fieldset>
            <div class="body-title mb-10"><%= t("admin.settings.default_order_status") %></div>
            <div class="select">
              <%= form.select :default_order_status, Setting::ORDER_STATUSES.map { |s| [translated_order_status(s), s] } %>
            </div>
          </fieldset>
        </div>
      </div>

      <div class="product-form-actions">
        <button class="tf-button" type="submit"><i class="icon-save"></i><%= t("admin.common.save_changes") %></button>
      </div>
    <% end %>
  </div>
</div>
