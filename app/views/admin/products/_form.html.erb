<%= form_with model: [:admin, @product], local: true, html: { multipart: true, class: "product-form" }, data: { controller: "product-form" } do |form| %>
  <% if @product.errors.any? %>
    <div class="wg-box product-form-errors mb-30">
      <div class="body-title"><%= t("admin.products.form_errors") %></div>
      <ul>
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="product-form-grid">
    <div class="wg-box product-form-media">
      <div>
        <div class="body-title mb-10"><%= t("admin.products.images") %></div>
        <div class="text-tiny"><%= t("admin.products.images_hint") %></div>
      </div>

      <div class="upload-image mb-16">
        <div class="up-load">
          <label class="uploadfile product-form-upload" for="product_images">
            <span class="icon">
              <i class="icon-upload-cloud"></i>
            </span>
            <div class="text-tiny">
              <%= t("admin.products.drop_images") %>
              <span class="text-secondary"><%= t("admin.products.browse_files") %></span>
            </div>
            <%= form.file_field :images,
                                multiple: true,
                                direct_upload: true,
                                id: "product_images",
                                accept: "image/*",
                                onchange: "previewImages(event)" %>
          </label>
          <div id="preview-images" class="image-preview-grid mt-4 d-none"></div>
        </div>
      </div>

      <% if @product.images.attached? %>
        <div>
          <div class="body-title mb-10"><%= t("admin.products.current_images") %></div>
          <div class="product-form-current-images">
            <% @product.images.each do |image| %>
              <div class="product-form-current-image">
                <%= image_tag image.variant(resize_to_fill: [220, 220]), alt: @product.name %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="wg-box product-form-fields">
      <div>
        <div class="body-title mb-10"><%= t("admin.products.product_information") %></div>
        <div class="text-tiny"><%= t("admin.products.product_information_hint") %></div>
      </div>

      <fieldset class="name">
        <div class="body-title mb-10"><%= t("admin.products.product_title") %> <span class="tf-color-1">*</span></div>
        <%= form.text_field :name, placeholder: t("admin.products.product_title_placeholder"), required: true %>
      </fieldset>

      <div class="product-form-two-columns">
        <fieldset class="category">
          <div class="body-title mb-10"><%= t("admin.products.category") %> <span class="tf-color-1">*</span></div>
          <div class="select">
            <%= form.select :category_id,
                            options_for_select(category_options, @product.category_id),
                            { prompt: t("admin.products.choose_category") },
                            { data: { product_form_target: "categorySelect", action: "change->product-form#categoryChanged" } } %>
          </div>
        </fieldset>

        <fieldset class="price">
          <div class="body-title mb-10"><%= t("admin.products.price") %> <span class="tf-color-1" data-product-form-target="requiredMark">*</span></div>
          <%= form.number_field :price, placeholder: t("admin.products.price"), required: true, step: 0.01, min: 0, data: { product_form_target: "input" } %>
          <div class="text-tiny mt-2" data-product-form-target="note" hidden><%= t("admin.products.price_from_variations") %></div>
        </fieldset>
      </div>

      <fieldset class="description">
        <div class="body-title mb-10"><%= t("admin.products.description") %></div>
        <%= form.text_area :description, placeholder: t("admin.products.description_placeholder"), rows: 8 %>
      </fieldset>
    </div>
  </div>

  <%# Simple options: colors + storage capacities. Used by non-variant categories. %>
  <div class="wg-box product-form-options" data-product-form-target="simpleSection">
    <div>
      <div class="body-title mb-10"><%= t("admin.products.options") %></div>
      <div class="text-tiny"><%= t("admin.products.options_hint") %></div>
    </div>

    <fieldset class="product-form-option-group">
      <div class="body-title mb-10"><%= t("admin.products.colors") %></div>
      <% if color_options.any? %>
        <div class="option-color-grid">
          <%= form.collection_check_boxes :color_ids, color_options, :id, :name do |b| %>
            <%= b.label(class: "option-color") do %>
              <%= b.check_box %>
              <span class="option-color__swatch" style="--swatch: <%= b.object.hex %>"></span>
              <span class="option-color__name"><%= b.object.name %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-tiny"><%= t("admin.products.no_colors") %> <%= link_to t("admin.products.manage_colors"), admin_settings_colors_path %></div>
      <% end %>
    </fieldset>

    <fieldset class="product-form-option-group">
      <div class="body-title mb-10"><%= t("admin.products.storages") %></div>
      <div class="text-tiny mb-16"><%= t("admin.products.storages_hint") %></div>
      <% if storage_options.any? %>
        <div class="option-storage-list">
          <% Storage.all.each do |storage| %>
            <% existing = @product.product_storages.detect { |ps| ps.storage_id == storage.id } %>
            <div class="option-storage">
              <label class="option-storage__toggle" for="storage_enabled_<%= storage.id %>">
                <%= check_box_tag "product_storages[#{storage.id}][enabled]", "1", existing.present?, id: "storage_enabled_#{storage.id}", class: "option-check-input", data: { product_form_target: "storage", action: "change->product-form#refreshPrice" } %>
                <span class="option-check-box"></span>
                <span class="option-storage__value"><%= storage.value %></span>
              </label>
              <div class="option-storage__price">
                <%= number_field_tag "product_storages[#{storage.id}][price]", existing&.price, step: 0.01, min: 0, placeholder: t("admin.products.storage_price"), aria: { label: "#{t("admin.products.storage_price")} - #{storage.value}" } %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-tiny"><%= t("admin.products.no_storages") %> <%= link_to t("admin.products.manage_storages"), admin_settings_storages_path %></div>
      <% end %>
    </fieldset>
  </div>

  <%# Variation builder: color + RAM + storage + price per row. Used by variant categories. %>
  <div class="wg-box product-form-options" data-product-form-target="variantSection" hidden>
    <div>
      <div class="body-title mb-10"><%= t("admin.products.variations") %></div>
      <div class="text-tiny"><%= t("admin.products.variations_hint") %></div>
    </div>

    <div class="variation-builder">
      <div class="variation-builder__controls">
        <fieldset class="variation-builder__field">
          <div class="body-title mb-10"><%= t("admin.products.variation_color") %></div>
          <div class="select">
            <select data-product-form-target="variantColor">
              <option value=""><%= t("admin.products.variation_no_color") %></option>
              <% color_options.each do |color| %>
                <option value="<%= color.id %>" data-hex="<%= color.hex %>"><%= color.name %></option>
              <% end %>
            </select>
          </div>
        </fieldset>

        <fieldset class="variation-builder__field">
          <div class="body-title mb-10"><%= t("admin.products.variation_memory") %></div>
          <div class="select">
            <select data-product-form-target="variantMemory">
              <%= options_for_select(memory_options) %>
            </select>
          </div>
        </fieldset>

        <fieldset class="variation-builder__field">
          <div class="body-title mb-10"><%= t("admin.products.variation_storage") %></div>
          <div class="select">
            <select data-product-form-target="variantStorage">
              <%= options_for_select(storage_options) %>
            </select>
          </div>
        </fieldset>

        <fieldset class="variation-builder__field">
          <div class="body-title mb-10"><%= t("admin.products.variation_price") %></div>
          <input type="number" step="0.01" min="0" placeholder="<%= t("admin.products.storage_price") %>" data-product-form-target="variantPrice">
        </fieldset>

        <button type="button" class="tf-button style-3 variation-builder__add" data-action="product-form#addVariation">
          <i class="icon-plus"></i><%= t("admin.products.add_variation") %>
        </button>
      </div>

      <p class="text-tiny variation-builder__error" data-product-form-target="variantError" role="alert" hidden
         data-incomplete="<%= t("admin.products.variation_incomplete") %>"
         data-duplicate="<%= t("admin.products.variation_duplicate") %>"
         data-no-color="<%= t("admin.products.variation_no_color") %>"></p>

      <div class="variation-builder__list" data-product-form-target="variantList">
        <% @product.product_variants.includes(:color, :memory, :storage).sort_by(&:price).each do |variant| %>
          <%= render "admin/products/variation_row", variant: variant %>
        <% end %>
      </div>

      <p class="text-tiny variation-builder__empty" data-product-form-target="variantEmpty"
         <%= "hidden" if @product.product_variants.any? %>><%= t("admin.products.no_variations") %></p>
    </div>
  </div>

  <div class="product-form-actions">
    <button class="tf-button" type="submit">
      <i class="icon-save"></i><%= @product.persisted? ? t("admin.products.update") : t("admin.products.create") %>
    </button>
    <% if @product.persisted? %>
      <%= link_to admin_product_path(@product), class: "tf-button style-3" do %>
        <i class="icon-arrow-left"></i><%= t("admin.common.cancel") %>
      <% end %>
    <% else %>
      <%= link_to admin_products_path, class: "tf-button style-3" do %>
        <i class="icon-arrow-left"></i><%= t("admin.common.cancel") %>
      <% end %>
    <% end %>
  </div>
<% end %>
