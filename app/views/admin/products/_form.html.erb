<%= form_with model: [:admin, @product], local: true, html: { multipart: true, class: "product-form" }, data: { controller: "product-price-mode" } do |form| %>
  <% if @product.errors.any? %>
    <div class="wg-box product-form-errors mb-30">
      <div class="body-title"><%= t("admin.products.form_errors") %></div>
      <ul>
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="product-form-grid">
    <div class="wg-box product-form-media">
      <div>
        <div class="body-title mb-10"><%= t("admin.products.images") %></div>
        <div class="text-tiny"><%= t("admin.products.images_hint") %></div>
      </div>

      <div class="upload-image mb-16">
        <div class="up-load">
          <label class="uploadfile product-form-upload" for="product_images">
            <span class="icon">
              <i class="icon-upload-cloud"></i>
            </span>
            <div class="text-tiny">
              <%= t("admin.products.drop_images") %>
              <span class="text-secondary"><%= t("admin.products.browse_files") %></span>
            </div>
            <%= form.file_field :images,
                                multiple: true,
                                direct_upload: true,
                                id: "product_images",
                                accept: "image/*",
                                onchange: "previewImages(event)" %>
          </label>
          <div id="preview-images" class="image-preview-grid mt-4 d-none"></div>
        </div>
      </div>

      <% if @product.images.attached? %>
        <div>
          <div class="body-title mb-10"><%= t("admin.products.current_images") %></div>
          <div class="product-form-current-images">
            <% @product.images.each do |image| %>
              <div class="product-form-current-image">
                <%= image_tag image.variant(resize_to_fill: [220, 220]), alt: @product.name %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="wg-box product-form-fields">
      <div>
        <div class="body-title mb-10"><%= t("admin.products.product_information") %></div>
        <div class="text-tiny"><%= t("admin.products.product_information_hint") %></div>
      </div>

      <fieldset class="name">
        <div class="body-title mb-10"><%= t("admin.products.product_title") %> <span class="tf-color-1">*</span></div>
        <%= form.text_field :name, placeholder: t("admin.products.product_title_placeholder"), required: true %>
      </fieldset>

      <div class="product-form-two-columns">
        <fieldset class="category">
          <div class="body-title mb-10"><%= t("admin.products.category") %> <span class="tf-color-1">*</span></div>
          <div class="select">
            <%= form.select :category_id, category_options, { prompt: t("admin.products.choose_category") } %>
          </div>
        </fieldset>

        <fieldset class="price">
          <div class="body-title mb-10"><%= t("admin.products.price") %> <span class="tf-color-1" data-product-price-mode-target="requiredMark">*</span></div>
          <%= form.number_field :price, placeholder: t("admin.products.price"), required: true, step: 0.01, min: 0, data: { product_price_mode_target: "input" } %>
          <div class="text-tiny mt-2" data-product-price-mode-target="note" hidden><%= t("admin.products.price_from_variations") %></div>
        </fieldset>
      </div>

      <fieldset class="description">
        <div class="body-title mb-10"><%= t("admin.products.description") %></div>
        <%= form.text_area :description, placeholder: t("admin.products.description_placeholder"), rows: 8 %>
      </fieldset>
    </div>
  </div>

  <div class="wg-box product-form-options">
    <div>
      <div class="body-title mb-10"><%= t("admin.products.options") %></div>
      <div class="text-tiny"><%= t("admin.products.options_hint") %></div>
    </div>

    <fieldset class="product-form-option-group">
      <div class="body-title mb-10"><%= t("admin.products.colors") %></div>
      <% if color_options.any? %>
        <div class="option-color-grid">
          <%= form.collection_check_boxes :color_ids, color_options, :id, :name do |b| %>
            <%= b.label(class: "option-color") do %>
              <%= b.check_box %>
              <span class="option-color__swatch" style="--swatch: <%= b.object.hex %>"></span>
              <span class="option-color__name"><%= b.object.name %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-tiny"><%= t("admin.products.no_colors") %> <%= link_to t("admin.products.manage_colors"), admin_settings_colors_path %></div>
      <% end %>
    </fieldset>

    <fieldset class="product-form-option-group">
      <div class="body-title mb-10"><%= t("admin.products.memory_variants") %></div>
      <div class="text-tiny mb-16"><%= t("admin.products.memory_variants_hint") %></div>
      <div class="option-storage-list">
        <% Memory.all.each do |memory| %>
          <% Storage.all.each do |storage| %>
            <% existing = @product.product_variants.detect { |variant| variant.memory_id == memory.id && variant.storage_id == storage.id } %>
            <div class="option-storage">
              <label class="option-storage__toggle" for="variant_enabled_<%= memory.id %>_<%= storage.id %>">
                <%= check_box_tag "product_variants[#{memory.id}][#{storage.id}][enabled]", "1", existing.present?, id: "variant_enabled_#{memory.id}_#{storage.id}", class: "option-check-input", data: { product_price_mode_target: "variant", action: "change->product-price-mode#refresh" } %>
                <span class="option-check-box"></span>
                <span class="option-storage__value"><%= memory.value %> RAM · <%= storage.value %></span>
              </label>
              <div class="option-storage__price">
                <%= number_field_tag "product_variants[#{memory.id}][#{storage.id}][price]", existing&.price, step: 0.01, min: 0, placeholder: t("admin.products.storage_price"), aria: { label: "#{t("admin.products.storage_price")} - #{memory.value} RAM - #{storage.value}" } %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </fieldset>

    <fieldset class="product-form-option-group">
      <div class="body-title mb-10"><%= t("admin.products.storages") %></div>
      <div class="text-tiny mb-16"><%= t("admin.products.storages_hint") %></div>
      <% if storage_options.any? %>
        <div class="option-storage-list">
          <% Storage.all.each do |storage| %>
            <% existing = @product.product_storages.detect { |ps| ps.storage_id == storage.id } %>
            <div class="option-storage">
              <label class="option-storage__toggle" for="storage_enabled_<%= storage.id %>">
                <%= check_box_tag "product_storages[#{storage.id}][enabled]", "1", existing.present?, id: "storage_enabled_#{storage.id}", class: "option-check-input", data: { product_price_mode_target: "storage", action: "change->product-price-mode#refresh" } %>
                <span class="option-check-box"></span>
                <span class="option-storage__value"><%= storage.value %></span>
              </label>
              <div class="option-storage__price">
                <%= number_field_tag "product_storages[#{storage.id}][price]", existing&.price, step: 0.01, min: 0, placeholder: t("admin.products.storage_price"), aria: { label: "#{t("admin.products.storage_price")} - #{storage.value}" } %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-tiny"><%= t("admin.products.no_storages") %> <%= link_to t("admin.products.manage_storages"), admin_settings_storages_path %></div>
      <% end %>
    </fieldset>
  </div>

  <div class="product-form-actions">
    <button class="tf-button" type="submit">
      <i class="icon-save"></i><%= @product.persisted? ? t("admin.products.update") : t("admin.products.create") %>
    </button>
    <% if @product.persisted? %>
      <%= link_to admin_product_path(@product), class: "tf-button style-3" do %>
        <i class="icon-arrow-left"></i><%= t("admin.common.cancel") %>
      <% end %>
    <% else %>
      <%= link_to admin_products_path, class: "tf-button style-3" do %>
        <i class="icon-arrow-left"></i><%= t("admin.common.cancel") %>
      <% end %>
    <% end %>
  </div>
<% end %>
