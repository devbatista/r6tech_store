<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <!-- main-content-wrap -->
  <div class="main-content-wrap">
    <div class="flex items-center flex-wrap justify-between gap20 mb-30">
      <h3><%= t("admin.products.add") %></h3>
      <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
        <li>
          <%= link_to admin_dashboard_path do %><div class="text-tiny"><%= t("admin.navigation.dashboard") %></div><% end %>
        </li>
        <li>
          <i class="icon-chevron-right"></i>
        </li>
        <li>
          <%= link_to admin_products_path do %><div class="text-tiny"><%= t("admin.navigation.products") %></div><% end %>
        </li>
        <li>
          <i class="icon-chevron-right"></i>
        </li>
        <li>
          <div class="text-tiny"><%= t("admin.products.add") %></div>
        </li>
      </ul>
    </div>
    <!-- form-add-product -->
    <%= render "form" %>
    <!-- /form-add-product -->
  </div>
  <!-- /main-content-wrap -->
</div>
