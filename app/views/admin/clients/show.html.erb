<div class="main-content-inner">
  <%= render 'layouts/flash' %>

  <div class="main-content-wrap">
    <div class="product-show-header mb-30">
      <div class="product-show-title">
        <h3><%= @client.name %></h3>
        <div class="product-show-subtitle">
          <span><%= @client.email %></span>
          <span><%= t("admin.clients.order_count", count: @orders_count) %></span>
        </div>
      </div>

      <div class="product-show-header-actions">
        <%= link_to admin_clients_path, class: "tf-button style-3" do %>
          <i class="icon-arrow-left"></i><%= t("admin.common.back") %>
        <% end %>
      </div>

      <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
        <li>
          <%= link_to admin_root_path do %>
            <div class="text-tiny"><%= t("admin.navigation.dashboard") %></div>
          <% end %>
        </li>
        <li><i class="icon-chevron-right"></i></li>
        <li>
          <%= link_to admin_clients_path do %>
            <div class="text-tiny"><%= t("admin.navigation.clients") %></div>
          <% end %>
        </li>
        <li><i class="icon-chevron-right"></i></li>
        <li>
          <div class="text-tiny"><%= t("admin.common.details") %></div>
        </li>
      </ul>
    </div>

    <div class="product-show-grid product-show-grid-compact mb-30">
      <div class="wg-box product-show-panel">
        <div>
          <div class="body-title mb-10"><%= t("admin.clients.personal_information") %></div>
          <div class="text-tiny"><%= t("admin.clients.account_details") %></div>
        </div>

        <div class="divider"></div>

        <div class="product-show-details-list">
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.name") %></span>
            <strong><%= @client.name %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.email") %></span>
            <strong><%= @client.email %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.phone") %></span>
            <strong><%= @client.phone.presence || "—" %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.birthdate") %></span>
            <strong><%= @client.birthdate ? l(@client.birthdate, format: :long) : "—" %></strong>
          </div>
          <div class="product-show-detail-row">
            <span><%= t("admin.clients.member_since") %></span>
            <strong><%= l(@client.created_at, format: :short) %></strong>
          </div>
        </div>
      </div>

      <div class="wg-box product-show-panel">
        <div>
          <div class="body-title mb-10"><%= t("admin.clients.addresses") %></div>
          <div class="text-tiny"><%= t("admin.clients.address_count", count: @addresses.size) %></div>
        </div>

        <div class="divider"></div>

        <% if @addresses.any? %>
          <ul class="flex flex-column has-divider-line">
            <% @addresses.each do |address| %>
              <li style="padding: 10px 0;">
                <div class="flex items-center gap10 mb-4">
                  <div class="body-title-2"><%= address.label.presence || t("admin.clients.address") %></div>
                  <% if address.default? %>
                    <div class="block-available fw-7"><%= t("admin.clients.default") %></div>
                  <% end %>
                </div>
                <div class="text-tiny"><%= address.full_line %></div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="body-text text-tiny"><%= t("admin.clients.no_addresses") %></div>
        <% end %>
      </div>
    </div>

    <div class="wg-box">
      <div class="flex items-center justify-between">
        <h5><%= t("admin.clients.recent_orders") %></h5>
        <%= link_to t("admin.clients.view_all_orders"), admin_orders_path, class: "tf-button style-3" %>
      </div>
      <div class="wg-table table-all-category">
        <ul class="table-title flex gap20 mb-14">
          <li><div class="body-title"><%= t("admin.orders.order") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.items") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.total") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.date") %></div></li>
          <li><div class="body-title"><%= t("admin.orders.status") %></div></li>
          <li><div class="body-title"><%= t("admin.common.action") %></div></li>
        </ul>
        <ul class="flex flex-column">
          <% @recent_orders.each do |order| %>
          <li class="wg-product item-row gap20">
            <div class="name">
              <div class="image">
                <% first_product = order.order_items.first&.product %>
                <% if first_product %>
                  <%= product_thumbnail_tag(first_product, alt: first_product.name) %>
                <% else %>
                  <span class="icon-shopping-cart" style="font-size: 24px;"></span>
                <% end %>
              </div>
              <div class="title line-clamp-2 mb-0">
                <%= link_to "##{order.id[0, 8]}", admin_order_path(order), class: "body-text fw-6" %>
              </div>
            </div>
            <div class="body-text text-main-dark mt-4"><%= order.order_items.sum { |i| i.quantity.to_i } %></div>
            <div class="body-text text-main-dark mt-4"><%= number_to_currency(order.total) %></div>
            <div class="body-text text-main-dark mt-4"><%= l(order.created_at, format: :short) %></div>
            <div>
              <div class="<%= order_status_badge_class(order.status) %> bg-1 fw-7"><%= translated_order_status(order.status) %></div>
            </div>
            <div class="list-icon-function">
              <div class="item eye">
                <%= link_to admin_order_path(order) do %>
                  <i class="icon-eye"></i>
                <% end %>
              </div>
            </div>
          </li>
          <% end %>
          <% if @recent_orders.empty? %>
          <li class="wg-product item-row gap20">
            <div class="body-text text-tiny"><%= t("admin.clients.no_orders") %></div>
          </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
