<% content_for :title, "#{@product.name} | #{storefront_name}" %>
<section class="store-section"><div class="store-container product-detail">
  <div class="product-gallery">
    <% if @product.images.attached? %>
      <% @product.images.each do |image| %><%= image_tag image, alt: @product.name %><% end %>
    <% else %>
      <%= image_tag "storefront/product-placeholder.jpg", alt: @product.name %>
    <% end %>
  </div>
  <% variant_data = @product.product_variants.includes(:memory, :storage).map { |v| { id: v.id, colorId: v.color_id.to_s, memoryId: v.memory_id, storageId: v.storage_id, price: v.price.to_f } } %>
  <div class="product-info" data-controller="product-options" data-product-options-variants-value="<%= variant_data.to_json %>">
    <%= link_to @product.category.name, products_path(category_id: @product.category_id), class: "product-info__category" %>
    <h1><%= @product.name %></h1>
    <strong class="product-info__price" data-product-options-target="price"><%= number_to_currency(@product.from_price) %></strong>
    <p><%= @product.description.presence || t("storefront.product.no_description") %></p>

    <%= form_with url: cart_items_path, class: "add-form" do |form| %>
      <% product_colors = @product.display_colors.to_a %>
      <% if product_colors.any? %>
        <fieldset class="option-group">
          <legend class="option-group__label">
            <%= t("storefront.product.color") %>:
            <span data-product-options-target="colorName"><%= product_colors.first.name %></span>
          </legend>
          <div class="option-swatches">
            <% product_colors.each_with_index do |color, index| %>
              <label class="swatch" title="<%= color.name %>">
                <%= radio_button_tag "color_id", color.id, index.zero?, required: true,
                      data: { product_options_target: "color", action: "product-options#selectColor", "color-name": color.name } %>
                <span class="swatch__dot" style="background: <%= color.hex %>"></span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% else %>
        <p class="product-info__consult"><%= t("storefront.product.consult_availability") %></p>
      <% end %>

      <% if @product.product_variants.any? %>
        <%= hidden_field_tag "variant_id", nil, data: { product_options_target: "variantId" } %>
        <fieldset class="option-group">
          <legend class="option-group__label"><%= t("storefront.product.configuration") %></legend>
          <div class="option-storages">
            <% configs = @product.product_variants.includes(:memory, :storage).sort_by(&:price).map { |v| [v.memory_id, v.storage_id, v.memory.value, v.storage.value] }.uniq { |c| [c[0], c[1]] } %>
            <% configs.each_with_index do |(memory_id, storage_id, memory_value, storage_value), index| %>
              <label class="storage-pill">
                <%= radio_button_tag "config", "#{memory_id}:#{storage_id}", index.zero?,
                      data: { product_options_target: "config", action: "product-options#selectConfig",
                              memory_id: memory_id, storage_id: storage_id } %>
                <span class="storage-pill__value"><%= memory_value %> RAM · <%= storage_value %></span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% elsif @product.product_storages.any? %>
        <fieldset class="option-group">
          <legend class="option-group__label"><%= t("storefront.product.storage") %></legend>
          <div class="option-storages">
            <% @product.product_storages.includes(:storage).sort_by(&:price).each_with_index do |ps, index| %>
              <label class="storage-pill">
                <%= radio_button_tag "storage_id", ps.storage_id, index.zero?, required: true,
                      data: { action: "product-options#selectStorage", price: ps.price.to_s } %>
                <span class="storage-pill__value"><%= ps.storage.value %></span>
                <span class="storage-pill__price"><%= number_to_currency(ps.price) %></span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% end %>

      <div class="add-form__buy">
        <div class="add-form__quantity">
          <label><%= t("storefront.product.quantity") %></label>
          <%= form.number_field :quantity, value: 1, min: 1 %>
        </div>
        <%= form.hidden_field :product_id, value: @product.id %>
        <button class="store-button store-button--dark"><%= t("storefront.cart.add") %></button>
      </div>
    <% end %>

    <div class="product-assurances"><span>✓ <%= t("storefront.product.secure") %></span><span>✓ <%= t("storefront.product.shipping") %></span></div>
  </div>
</div></section>
<% if @related_products.any? %><section class="store-section store-section--muted"><div class="store-container"><div class="section-heading"><h2><%= t("storefront.product.related") %></h2></div><div class="product-grid"><%= render partial: "storefront/product_card", collection: @related_products, as: :product %></div></div></section><% end %>
