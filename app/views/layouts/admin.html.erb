<!DOCTYPE html>
<!--[if IE 8 ]><html class="ie" xmlns="http://www.w3.org/1999/xhtml" xml:lang="<%= I18n.locale %>" lang="<%= I18n.locale %>"> <![endif]-->
<!--[if (gte IE 9)|!(IE)]><!-->
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="<%= I18n.locale %>" lang="<%= I18n.locale %>">
<!--<![endif]-->

<!-- filepath: app/views/layouts/admin.html.erb -->

<head>
  <meta charset="utf-8">
  <!--[if IE]><meta http-equiv='X-UA-Compatible' content='IE=edge,chrome=1'><![endif]-->
  <title>R6tech Store</title>
  <%= csrf_meta_tags %>
  <meta name="author" content="Rafael Batista">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

  <!-- Rails asset helpers -->
  <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "css/animate.min", 
                          "css/animation",
                          "css/bootstrap",
                          "css/bootstrap-select.min",
                          "css/styles",
                          "admin_options",
                          "font/fonts",
                          "icon/style", media: "all" %>

  <%= favicon_link_tag "favicon.png" %>
  <link rel="apple-touch-icon-precomposed" href="<%= asset_path('favicon.png') %>">
  <%= javascript_importmap_tags %>
</head>

<body>

  <!-- #wrapper -->
  <div id="wrapper">
    <!-- #page -->
    <div id="page" class="">
      <!-- layout-wrap -->
      <div class="layout-wrap">
        <!-- preload -->
        <div id="preload" class="preload-container">
          <div class="preloading">
            <span></span>
          </div>
        </div>
        <!-- /preload -->
        <!-- section-menu-left -->
        <div class="section-menu-left">
          <div class="box-logo">
            <%= link_to admin_dashboard_path, id: "site-logo-inner" do %>
            <%= image_tag "logo/logo.svg", id: "logo_header", alt: "", data: { light: asset_path("logo/logo.svg"), dark: asset_path("logo/logo-white.svg") } %>
            <% end %>
            <div class="button-show-hide">
              <i class="icon-chevron-left"></i>
            </div>
          </div>
          <div class="section-menu-left-wrap">
            <div class="center">
              <div class="center-item">
                <ul class="">
                  <li class="menu-item">
                    <%= link_to admin_dashboard_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-home"></i></div>
                    <div class="text"><%= t("admin.navigation.dashboard") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item">
                    <%= link_to admin_products_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-file-plus"></i></div>
                    <div class="text"><%= t("admin.navigation.products") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item">
                    <%= link_to admin_categories_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-layers"></i></div>
                    <div class="text"><%= t("admin.navigation.categories") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item">
                    <%= link_to admin_orders_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-file-text"></i></div>
                    <div class="text"><%= t("admin.navigation.orders") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item">
                    <%= link_to admin_clients_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-user"></i></div>
                    <div class="text"><%= t("admin.navigation.clients") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item mt-3">
                    <%= link_to root_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-globe"></i></div>
                    <div class="text"><%= t("admin.navigation.back_to_shop") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item mt-3">
                    <%= link_to admin_settings_store_path, class: "nav-link" do %>
                    <div class="icon"><i class="icon-settings"></i></div>
                    <div class="text"><%= t("admin.navigation.settings") %></div>
                    <% end %>
                  </li>
                  <li class="menu-item">
                    <%= link_to logout_path, data: { turbo_method: :delete }, class: "nav-link" do %>
                    <div class="icon"><i class="icon-log-out"></i></div>
                    <div class="text"><%= t("admin.navigation.logout") %></div>
                    <% end %>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
        <!-- /section-menu-left -->
        <!-- section-content-right -->
        <div class="section-content-right">
          <!-- header-dashboard -->
          <div class="header-dashboard">
            <div class="wrap">
              <div class="header-left">
                <%= link_to admin_dashboard_path do %>
                  <%= image_tag "logo/logo.svg", id: "logo_header_mobile", alt: "", data: { light: asset_path("logo/logo.svg"), dark: asset_path("logo/logo-white.svg") } %>
                <% end %>
                <div class="button-show-hide">
                  <i class="icon-chevron-left"></i>
                </div>
                <form class="form-search flex-grow">
                  <fieldset class="name">
                    <input type="text" placeholder="<%= t("admin.navigation.search") %>" class="show-search" name="name" tabindex="2" value="" aria-required="true" required="">
                  </fieldset>
                  <div class="button-submit">
                    <button class="" type="submit"><i class="icon-search"></i></button>
                  </div>
                  <div class="box-content-search" id="box-content-search">
                    <ul class="mb-24">
                      <li class="mb-14">
                        <div class="body-title"><%= t("admin.dashboard.top_sale") %></div>
                      </li>
                      <li class="mb-14">
                        <div class="divider"></div>
                      </li>
                      <li>
                        <ul>
                          <li class="product-item gap14 mb-10">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-1.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Neptune Longsleeve</a>
                              </div>
                            </div>
                          </li>
                          <li class="mb-10">
                            <div class="divider"></div>
                          </li>
                          <li class="product-item gap14 mb-10">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-2.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Ribbed Tank Top</a>
                              </div>
                            </div>
                          </li>
                          <li class="mb-10">
                            <div class="divider"></div>
                          </li>
                          <li class="product-item gap14">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-3.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Ribbed modal T-shirt</a>
                              </div>
                            </div>
                          </li>
                        </ul>
                      </li>
                    </ul>
                    <ul class="">
                      <li class="mb-14">
                        <div class="body-title"><%= t("admin.navigation.orders") %></div>
                      </li>
                      <li class="mb-14">
                        <div class="divider"></div>
                      </li>
                      <li>
                        <ul>
                          <li class="product-item gap14 mb-10">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-4.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Oversized Motif T-shirt</a>
                              </div>
                            </div>
                          </li>
                          <li class="mb-10">
                            <div class="divider"></div>
                          </li>
                          <li class="product-item gap14 mb-10">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-5.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">V-neck linen T-shirt</a>
                              </div>
                            </div>
                          </li>
                          <li class="mb-10">
                            <div class="divider"></div>
                          </li>
                          <li class="product-item gap14 mb-10">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-6.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Jersey thong body</a>
                              </div>
                            </div>
                          </li>
                          <li class="mb-10">
                            <div class="divider"></div>
                          </li>
                          <li class="product-item gap14">
                            <div class="image no-bg">
                              <img src="<%= asset_path('products/product-7.jpg') %>" alt="">
                            </div>
                            <div class="flex items-center justify-between gap20 flex-grow">
                              <div class="name">
                                <a href="product-list.html" class="body-text">Jersey thong body</a>
                              </div>
                            </div>
                          </li>
                        </ul>
                      </li>
                    </ul>
                  </div>
                </form>
              </div>
              <div class="header-grid">
                <div class="header-item button-dark-light">
                  <i class="icon-moon"></i>
                </div>
                <div class="header-item country" title="<%= locale_switch_title %>">
                  <%= form_with url: request.path, method: :get, local: true, html: { class: "locale-switcher-form" } do %>
                    <% request.query_parameters.except("locale").each do |key, value| %>
                      <%= hidden_field_tag key, value %>
                    <% end %>
                    <%= select_tag :locale,
                                   options_for_select([
                                     [t("admin.common.portuguese"), "pt-BR", { "data-thumbnail": asset_path("country/4.png") }],
                                     [t("admin.common.english"), "en", { "data-thumbnail": asset_path("country/1.png") }]
                                   ], I18n.locale.to_s),
                                   class: "image-select",
                                   onchange: "this.form.submit()",
                                   "aria-label": locale_switch_title %>
                  <% end %>
                </div>
                <!-- Campo de notificações no header -->
                <div class="popup-wrap noti type-header">
                  <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                      <span class="header-item">
                        <span class="text-tiny">1</span>
                        <i class="icon-bell"></i>
                      </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end has-content" aria-labelledby="dropdownMenuButton1">
                      <li>
                        <h6><%= t("admin.settings.notifications") %></h6>
                      </li>
                      <li>
                        <div class="noti-item w-full wg-user active">
                          <div class="image">
                            <img src="<%= asset_path('customers/customer-1.jpg') %>" alt="">
                          </div>
                          <div class="flex-grow">
                            <div class="flex items-center justify-between">
                              <a href="#" class="body-title">Cameron Williamson</a>
                              <div class="time">10:13 PM</div>
                            </div>
                            <div class="text-tiny"><%= t("admin.common.sample_notification_hello") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="noti-item w-full wg-user active">
                          <div class="image">
                            <img src="<%= asset_path('customers/customer-2.jpg') %>" alt="">
                          </div>
                          <div class="flex-grow">
                            <div class="flex items-center justify-between">
                              <a href="#" class="body-title">Ralph Edwards</a>
                              <div class="time">10:13 PM</div>
                            </div>
                            <div class="text-tiny"><%= t("admin.common.sample_notification_interested") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="noti-item w-full wg-user active">
                          <div class="image">
                            <img src="<%= asset_path('customers/customer-3.jpg') %>" alt="">
                          </div>
                          <div class="flex-grow">
                            <div class="flex items-center justify-between">
                              <a href="#" class="body-title">Eleanor Pena</a>
                              <div class="time">10:13 PM</div>
                            </div>
                            <div class="text-tiny"><%= t("admin.common.sample_notification_loads") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="noti-item w-full wg-user active">
                          <div class="image">
                            <img src="<%= asset_path('customers/customer-1.jpg') %>" alt="">
                          </div>
                          <div class="flex-grow">
                            <div class="flex items-center justify-between">
                              <a href="#" class="body-title">Jane Cooper</a>
                              <div class="time">10:13 PM</div>
                            </div>
                            <div class="text-tiny"><%= t("admin.common.sample_notification_deal") %></div>
                          </div>
                        </div>
                      </li>
                      <li><a href="#" class="tf-button w-full"><%= t("admin.common.view_all") %></a></li>
                    </ul>
                  </div>
                </div>
                <!-- fim do campo de notificações no header -->
                <!-- Campo de mensagem no header -->
                <div class="popup-wrap message type-header">
                  <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton2" data-bs-toggle="dropdown" aria-expanded="false">
                      <span class="header-item">
                        <span class="text-tiny">1</span>
                        <i class="icon-message-square"></i>
                      </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end has-content" aria-labelledby="dropdownMenuButton2">
                      <li>
                        <h6><%= t("admin.common.messages") %></h6>
                      </li>
                      <li>
                        <div class="message-item item-1">
                          <div class="image">
                            <i class="icon-noti-1"></i>
                          </div>
                          <div>
                            <div class="body-title-2"><%= t("admin.common.discount_available") %></div>
                            <div class="text-tiny"><%= t("admin.common.sample_message_discount") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="message-item item-2">
                          <div class="image">
                            <i class="icon-noti-2"></i>
                          </div>
                          <div>
                            <div class="body-title-2"><%= t("admin.common.account_verified") %></div>
                            <div class="text-tiny"><%= t("admin.common.sample_message_account") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="message-item item-3">
                          <div class="image">
                            <i class="icon-noti-3"></i>
                          </div>
                          <div>
                            <div class="body-title-2"><%= t("admin.common.order_shipped_successfully") %></div>
                            <div class="text-tiny"><%= t("admin.common.sample_message_order") %></div>
                          </div>
                        </div>
                      </li>
                      <li>
                        <div class="message-item item-4">
                          <div class="image">
                            <i class="icon-noti-4"></i>
                          </div>
                          <div>
                            <div class="body-title-2"><%= t("admin.common.order_pending") %>: <span>ID 305830</span></div>
                            <div class="text-tiny"><%= t("admin.common.sample_message_pending") %></div>
                          </div>
                        </div>
                      </li>
                      <li><a href="#" class="tf-button w-full"><%= t("admin.common.view_all") %></a></li>
                    </ul>
                  </div>
                </div>
                <!-- Fim do campo de mensagem -->
                <!-- Campo de usuário -->
                <div class="popup-wrap user type-header">
                  <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton3" data-bs-toggle="dropdown" aria-expanded="false">
                      <span class="header-user wg-user">
                        <span class="image">
                          <img src="<%= asset_path('avatar/user-1.png') %>" alt="">
                        </span>
                        <span class="flex flex-column">
                          <span class="body-text text-main-dark"><%= current_user.name %></span>
                          <span class="text-tiny"><%= t("roles.#{current_user.role}", default: current_user.role.to_s.humanize) %></span>
                        </span>
                      </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end has-content" aria-labelledby="dropdownMenuButton3">
                      <li>
                        <a href="#" class="user-item">
                          <div class="icon">
                            <i class="icon-user"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.settings.account") %></div>
                        </a>
                      </li>
                      <li>
                        <a href="#" class="user-item">
                          <div class="icon">
                            <i class="icon-mail"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.common.inbox") %></div>
                          <div class="number">27</div>
                        </a>
                      </li>
                      <li>
                        <a href="#" class="user-item">
                          <div class="icon">
                            <i class="icon-file-text"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.common.taskboard") %></div>
                        </a>
                      </li>
                      <li>
                        <%= link_to admin_settings_account_path, class: "user-item" do %>
                          <div class="icon">
                            <i class="icon-settings"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.settings.account") %></div>
                        <% end %>
                      </li>
                      <li>
                        <a href="#" class="user-item">
                          <div class="icon">
                            <i class="icon-headphones"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.common.support") %></div>
                        </a>
                      </li>
                      <li>
                        <a href="login.html" class="user-item">
                          <div class="icon">
                            <i class="icon-log-out"></i>
                          </div>
                          <div class="body-title-2"><%= t("admin.navigation.logout") %></div>
                        </a>
                      </li>
                    </ul>
                  </div>
                </div>
                <!-- Fim do campo de usuário -->
              </div>
            </div>
          </div>
          <!-- /header-dashboard -->
          <!-- main-content -->
          <div class="main-content">
            <!-- main-content-wrap -->
            <%= yield %>
            <!-- /main-content-wrap -->
            <!-- bottom-page -->
            <div class="bottom-page">
              <div class="body-text">
                Copyright © <%= Time.current.year %>
                <a href="https://rbatista.dev/">Rafael Batista</a>.
                <%= t("admin.common.design_by") %> <a href="https://www.devbatista.com/">DevBatista</a> <%= t("store.footer_rights") %>
              </div>
            </div>
            <!-- /bottom-page -->
          </div>
          <!-- /main-content -->
        </div>
        <!-- /section-content-right -->
      </div>
      <!-- /layout-wrap -->
    </div>
    <!-- /#page -->
  </div>
  <!-- /#wrapper -->

  <!-- Javascript -->
  <%= javascript_include_tag "jquery.min" %>
  <%= javascript_include_tag "bootstrap.min" %>
  <%= javascript_include_tag "bootstrap-select.min" %>
  <%= javascript_include_tag "zoom" %>
  <%= yield :page_scripts %>
  <%= javascript_include_tag "switcher" %>
  <%= javascript_include_tag "theme-settings", defer: true %>
  <%= javascript_include_tag "main" %>

</body>

</html>
