<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : storefront_name %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "storefront/storefront", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag "storefront/product-placeholder.jpg" %>
  </head>
  <body class="storefront-body"
        data-controller="modal cart"
        data-modal-open-value="<%= params[:login].present? %>"
        data-action="keydown.esc@window->modal#close keydown.esc@window->cart#close">
    <%= render "storefront/announcement" %>
    <%= render "storefront/header" %>
    <%= render "layouts/flash" %>
    <main><%= yield %></main>
    <%= render "storefront/footer" %>
    <% if (whatsapp_url = storefront_whatsapp_url) %>
      <%= link_to whatsapp_url,
                  class: "whatsapp-float",
                  target: "_blank",
                  rel: "noopener",
                  aria: { label: "Atendimento pelo WhatsApp" } do %>
        <svg class="whatsapp-float__icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
          <defs>
            <linearGradient id="whatsapp-float-gradient" x1="32" y1="4" x2="32" y2="59" gradientUnits="userSpaceOnUse">
              <stop offset="0" stop-color="#42d96b" />
              <stop offset="1" stop-color="#00bf5c" />
            </linearGradient>
          </defs>
          <path class="whatsapp-float__bubble" d="M32 4C16.5 4 4 16.2 4 31.2c0 5.2 1.5 10.1 4.2 14.3L4.8 60l14.9-3.6A28.9 28.9 0 0 0 32 59.2c15.5 0 28-12.2 28-27.2S47.5 4 32 4Z" />
          <path class="whatsapp-float__phone" transform="translate(31 30.5) scale(.86) translate(-32 -32)" d="M23.3 17.2c-.7-1.6-1.4-1.6-2.1-1.6h-1.8c-.6 0-1.7.2-2.6 1.2-.9 1-3.4 3.3-3.4 8s3.5 9.3 4 9.9c.5.6 6.8 10.8 16.8 14.7 8.3 3.3 10 2.6 11.8 2.4 1.8-.3 5.8-2.4 6.6-4.7.8-2.3.8-4.3.6-4.7-.2-.4-.9-.6-1.9-1.1l-6.7-3.2c-.9-.4-1.6-.6-2.3.5-.7 1-2.7 3.2-3.3 3.9-.6.7-1.2.8-2.2.3-1-.5-4.2-1.5-8-4.8-3-2.6-5-5.8-5.6-6.8-.6-1 0-1.5.4-2 .4-.4 1-.9 1.5-1.5.5-.5.7-.9 1-1.6.3-.7.2-1.2-.1-1.7l-3.1-7.2Z" />
        </svg>
        <span>WhatsApp</span>
      <% end %>
    <% end %>
    <%= render "storefront/cart_drawer" %>
    <%= render "storefront/login_modal" unless current_user %>
  </body>
</html>
