<article class="product-card">
  <%= link_to product_path(product), class: "product-card__image" do %>
    <%= product_image(product) %>
  <% end %>
  <div class="product-card__body">
    <span class="product-card__category"><%= product.category&.name %></span>
    <h3><%= link_to product.name, product_path(product) %></h3>
    <div class="product-card__bottom">
      <strong><%= number_to_currency(product.price) %></strong>
      <%= button_to cart_items_path, params: { product_id: product.id, quantity: 1 }, class: "product-card__add", title: t("storefront.cart.add") do %>+<% end %>
    </div>
  </div>
</article>
