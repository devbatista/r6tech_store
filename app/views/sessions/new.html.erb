<% content_for :title, "#{t("store.login.title")} | #{storefront_name}" %>
<section class="auth-page">
  <div class="auth-page__media"><%= image_tag "storefront/hero/hero-2.jpg", alt: "" %></div>
  <div class="auth-page__content">
    <div class="auth-box">
      <span><%= storefront_name %></span>
      <h1><%= t("store.login.title") %></h1>
      <p><%= t("storefront.auth.welcome") %></p>
      <%= form_with url: login_path, method: :post, class: "auth-form" do |form| %>
        <label><%= t("store.login.email") %><%= form.email_field :email, placeholder: t("store.login.email_placeholder"), required: true, autofocus: true %></label>
        <label><%= t("store.login.password") %><%= form.password_field :password, placeholder: t("store.login.password_placeholder"), required: true %></label>
        <button class="store-button store-button--dark store-button--full"><%= t("store.login.submit") %></button>
      <% end %>
      <%= link_to t("storefront.auth.back"), root_path, class: "auth-box__back" %>
    </div>
  </div>
</section>
